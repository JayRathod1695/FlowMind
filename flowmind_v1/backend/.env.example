# API
CORS_ALLOWED_ORIGINS=http://localhost:5173
DEBUG=false

# Database
DB_PATH=./flowmind.db

# Log Storage (file-only)
LOG_FILE_PATH=./flowmind.logs.jsonl

# LLM Planner
LLM_API_KEY=
LLM_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_MODEL=qwen/qwen3.5-122b-a10b
LLM_STREAM_TERMINAL_ENABLED=true

# Encryption
TOKEN_ENCRYPTION_KEY=

# Jira OAuth
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
JIRA_REDIRECT_URI=http://localhost:8000/api/connectors/jira/callback

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/api/connectors/github/callback

# Slack OAuth
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=http://localhost:8000/api/connectors/slack/callback

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/connectors/google/callback
