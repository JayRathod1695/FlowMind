# API
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DEBUG=false

# Database
DB_PATH=./flowmind.db

# Log Storage
LOG_FILE_PATH=./flowmind.logs.jsonl
LOG_TERMINAL_ENABLED=true
# json | message
LOG_TERMINAL_FORMAT=json
# DEBUG | INFO | WARN | ERROR
LOG_TERMINAL_MIN_LEVEL=INFO

# LLM Planner
# You can set either LLM_API_KEY or NVIDIA_API_KEY
LLM_API_KEY=
NVIDIA_API_KEY=
LLM_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_MODEL=nvidia/nemotron-3-super-120b-a12b
LLM_TEMPERATURE=1
LLM_TOP_P=0.95
LLM_MAX_TOKENS=16384
LLM_ENABLE_THINKING=true
LLM_REASONING_BUDGET=16384
LLM_STREAM_TERMINAL_ENABLED=false

# Encryption
TOKEN_ENCRYPTION_KEY=

# Jira OAuth
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
JIRA_REDIRECT_URI=http://localhost:8000/api/connectors/jira/callback

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/api/connectors/github/callback

# Slack OAuth
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=http://localhost:8000/api/connectors/slack/callback

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/connectors/google/callback

# Testing MCP Agent (backend/Testing)
GITHUB_PERSONAL_ACCESS_TOKEN=
SLACK_BOT_TOKEN=
SLACK_TEAM_ID=
NOTION_API_TOKEN=
POSTGRES_CONNECTION_STRING=
LINEAR_API_KEY=
FILESYSTEM_PATH=/Users/your-user/Desktop/flowmind

# Jira for mcp-atlassian (either ATLASSIAN_* or JIRA_* can be used)
ATLASSIAN_BASE_URL=
ATLASSIAN_EMAIL=
ATLASSIAN_API_TOKEN=
JIRA_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=

# Gmail MCP local runner
GMAIL_CREDENTIALS_PATH=
GMAIL_TOKEN_PATH=
